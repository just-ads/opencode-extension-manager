{
  "name": "opencode-extension-manager",
  "version": "0.1.2",
  "description": "CLI for managing OpenCode extensions",
  "type": "module",
  "bin": {
    "oem": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs');fs.rmSync('dist',{recursive:true,force:true});\"",
    "build": "npm run clean && tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "opencode",
    "cli",
    "plugins",
    "extension-manager",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
